      font-size:12px;text-transform:uppercase;letter-spacing:0.08em;
      font-weight:800;padding:16px 18px;position:sticky;top:0;z-index:2;border-bottom:1px solid var(--border);white-space:nowrap;
    }
    tbody tr{transition:background .12s ease;}
    tbody tr:nth-child(odd){background:#fff;}
    tbody tr:nth-child(even){background:#f5f8fb;}
    tbody tr:hover{background:rgba(53,109,140,0.05);}
    td{padding:16px 18px;font-size:15px;border-bottom:1px solid #edf2f7;vertical-align:middle;}
    .asin-link{color:var(--accent);cursor:pointer;font-weight:700;font-family:'DM Mono',monospace;font-size:13px;background:none;border:none;text-decoration:none;transition:color .15s;padding:0;}
    .asin-link:hover{color:#2f627d;text-decoration:underline;}

    .badge,.meta-chip,.rec-chip,.risk-label-badge,.risk-level-badge,.vs-chip{
      display:inline-flex;align-items:center;gap:6px;padding:6px 12px;border-radius:999px;font-size:12px;font-weight:800;white-space:nowrap;
    }
    .badge-bad{background:rgba(198,90,90,0.10);color:var(--bad);border:1px solid rgba(198,90,90,0.22);}
    .badge-mid{background:rgba(183,134,61,0.11);color:var(--mid);border:1px solid rgba(183,134,61,0.22);}
    .badge-good{background:rgba(76,139,107,0.11);color:var(--good);border:1px solid rgba(76,139,107,0.22);}
    .badge-blue{background:var(--accent-soft);color:var(--accent);border:1px solid rgba(53,109,140,0.20);}
    .badge-purple{background:var(--accent-soft);color:var(--accent);border:1px solid rgba(53,109,140,0.20);}

    #drilldown-panel{display:none;animation:slideIn .25s ease;}
    #drilldown-panel.visible{display:block;}
    @keyframes slideIn{from{opacity:0;transform:translateY(10px);}to{opacity:1;transform:translateY(0);}}
    .drilldown-header{display:flex;align-items:flex-start;justify-content:space-between;gap:20px;margin-bottom:28px;padding-bottom:24px;border-bottom:1px solid var(--border);}
    .drilldown-title{font-size:1.3rem;font-weight:800;line-height:1.4;margin-bottom:10px;color:var(--text);}
    .drilldown-meta{display:flex;flex-wrap:wrap;gap:10px;align-items:center;margin-top:12px;}
    .meta-chip{font-size:13px;color:var(--muted);background:var(--surface-muted);border:1px solid var(--border);font-weight:600;}

    .risk-section{
      background:linear-gradient(180deg, rgba(247,250,252,0.96) 0%, rgba(241,246,250,0.96) 100%);border:1px solid var(--border);border-radius:var(--radius-lg);
      padding:28px;margin-bottom:26px;
    }
    .risk-header{display:flex;align-items:center;gap:16px;margin-bottom:20px;flex-wrap:wrap;}
    .risk-score-big{font-size:3rem;font-weight:900;letter-spacing:-0.05em;line-height:1;}
    .risk-bar-track{height:12px;border-radius:999px;background:#dde6ee;overflow:hidden;max-width:620px;margin-top:6px;}
    .risk-bar-fill{height:100%;border-radius:999px;transition:width .7s cubic-bezier(.4,0,.2,1);}
    .risk-breakdown{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:20px;margin-top:22px;padding-top:22px;border-top:1px solid var(--border);}
    .risk-stat{display:flex;flex-direction:column;gap:6px;}
    .risk-stat-val{font-size:1.35rem;font-weight:800;}
    .vs-better{background:rgba(76,139,107,0.10);color:var(--good);}
    .vs-worse{background:rgba(198,90,90,0.10);color:var(--bad);}

    .topic-grid{display:flex;flex-direction:column;gap:16px;}
    .topic-card{
      background:linear-gradient(180deg, rgba(247,250,252,0.96) 0%, rgba(241,246,250,0.96) 100%);border:1px solid var(--border);border-radius:14px;
      padding:18px 20px;box-shadow:none;
    }
    .topic-num{font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:10px;font-weight:800;}
    .topic-words{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:10px;}
    .topic-word{background:rgba(53,109,140,0.08);color:var(--accent);border:1px solid rgba(53,109,140,0.16);border-radius:999px;padding:5px 11px;font-size:13px;font-weight:700;}
    .topic-interp{font-size:13px;color:var(--muted);font-style:italic;}

    .rec-section{margin-top:18px;padding-top:18px;border-top:1px solid var(--border);}
    .rec-chips{display:flex;flex-wrap:wrap;gap:10px;}
    .rec-chip{background:var(--accent-soft);color:var(--accent);border:1px solid rgba(53,109,140,0.18);padding:8px 14px;font-size:13px;font-weight:700;}

    .chart-row{display:grid;grid-template-columns:minmax(0,1.6fr) minmax(260px,340px);gap:22px;margin-top:24px;align-items:start;}
    .chart-box,.insight-box,.compare-card,.xai-step{
      background:linear-gradient(180deg, rgba(247,250,252,0.96) 0%, rgba(241,246,250,0.96) 100%);border:1px solid var(--border);border-radius:var(--radius-lg);
      box-shadow:none;
    }
    .chart-box{padding:24px;min-width:0;}
    .brand-chart-wrap{position:relative;height:380px;}

    .insight-grid{display:grid;grid-template-columns:1fr 1.35fr;gap:22px;}
    .insight-box{padding:24px;min-width:0;}
    .worst-brand-row{display:flex;align-items:center;gap:12px;padding:13px 0;border-bottom:1px solid var(--border);}
    .worst-brand-row:last-child{border-bottom:none;}
    .rank-num{width:28px;height:28px;border-radius:50%;background:rgba(198,90,90,0.10);color:var(--bad);font-size:12px;font-weight:800;display:flex;align-items:center;justify-content:center;flex-shrink:0;border:1px solid rgba(198,90,90,0.16);}
    .brand-bar-outer{flex:1;height:8px;background:#dfe7ee;border-radius:999px;overflow:hidden;}
    .brand-bar-inner{height:100%;background:var(--bad);border-radius:999px;}

    .compare-row{display:flex;gap:16px;flex-wrap:wrap;align-items:end;margin-bottom:28px;}
    .compare-input-group{display:flex;flex-direction:column;gap:8px;min-width:220px;}
    .compare-grid{display:grid;grid-template-columns:1fr 1fr;gap:22px;}
    .compare-card{padding:24px 26px;display:flex;flex-direction:column;gap:18px;transition:border-color .18s ease,box-shadow .18s ease,transform .18s ease;}
    .compare-card.winner{border-color:rgba(76,139,107,.35);background:rgba(76,139,107,.05);box-shadow:0 0 0 3px rgba(76,139,107,.08);}
    .compare-card-name{font-size:15px;font-weight:800;line-height:1.45;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;color:var(--text);}
    .compare-card-asin{font-family:'DM Mono',monospace;font-size:12px;color:var(--muted);margin-top:4px;}
    .compare-metrics{display:flex;gap:22px;flex-wrap:wrap;border-top:1px solid var(--border);padding-top:18px;}
    .compare-metric{display:flex;flex-direction:column;gap:4px;}
    .compare-metric-val{font-size:1.55rem;font-weight:800;letter-spacing:-.03em;}
    .compare-win-tag{font-size:11px;font-weight:800;color:var(--good);margin-top:2px;}
    .compare-rec{font-size:14px;font-style:italic;padding-top:4px;line-height:1.6;}
    .compare-best-label{font-size:13px;font-weight:800;color:var(--good);border-top:1px solid rgba(76,139,107,.2);padding-top:12px;}
    .compare-vs{display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:800;color:var(--muted);align-self:center;padding:0 4px;}
    .compare-empty{text-align:center;padding:44px 20px;color:var(--muted);font-size:15px;background:var(--surface-soft);border:1px dashed var(--border-strong);border-radius:var(--radius-lg);}

    .xai-header{display:flex;align-items:center;gap:12px;margin-bottom:24px;}
    .xai-header-title{font-size:13px;font-weight:800;text-transform:uppercase;letter-spacing:.1em;color:var(--muted);display:flex;align-items:center;gap:12px;flex:1;}
    .xai-header-title::after{content:'';flex:1;height:1px;background:var(--border);}
    .xai-steps{display:flex;flex-direction:column;gap:16px;}
    .xai-step{display:flex;gap:18px;align-items:flex-start;padding:20px 22px;}
    .xai-step-num{width:34px;height:34px;border-radius:50%;background:var(--accent-soft);border:1px solid rgba(53,109,140,0.20);color:var(--accent);font-size:13px;font-weight:800;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:2px;}
    .xai-step-text{font-size:15px;color:var(--muted);line-height:1.8;}
    .xai-step-text strong{color:var(--text);}

    .spinner{width:22px;height:22px;border-radius:50%;border:2px solid var(--border-strong);border-top-color:var(--accent);animation:spin .7s linear infinite;flex-shrink:0;}
    @keyframes spin{to{transform:rotate(360deg);}}
    #toast{
      position:fixed;bottom:28px;right:28px;background:linear-gradient(180deg,#ffffff 0%,#f8fbfd 100%);border:1px solid var(--border);
      border-radius:14px;padding:14px 18px;font-size:14px;color:var(--text);box-shadow:var(--shadow-lg);
      transform:translateY(80px);opacity:0;transition:all .3s ease;z-index:9999;display:flex;align-items:center;gap:12px;
    }
    #toast.show{transform:translateY(0);opacity:1;}
    .asin-row{display:flex;gap:12px;align-items:center;flex-wrap:wrap;}
    .drilldown-empty{
      text-align:center;padding:72px 24px;color:var(--muted);background:linear-gradient(180deg, rgba(247,250,252,0.96) 0%, rgba(241,246,250,0.96) 100%);
      border:1px dashed var(--border-strong);border-radius:var(--radius-lg);
    }
    .drilldown-empty-icon{font-size:3.2rem;margin-bottom:16px;}
    a{color:var(--accent);text-decoration:none;}
    a:hover{text-decoration:underline;}
    .muted{color:var(--muted);}

    @media(max-width:1100px){
      .two-col,.insight-grid,.chart-row{grid-template-columns:1fr;}
      .two-col-side{width:auto;}
    }
    @media(max-width:768px){
      .project-banner{padding:40px 20px 32px;}
      .header{padding:0 18px;height:auto;min-height:72px;gap:14px;flex-wrap:wrap;justify-content:flex-start;padding-top:14px;padding-bottom:14px;}
      .wrap{padding:28px 16px 72px;gap:24px;}
      .card{padding:22px;}
      .kpi{padding:24px;min-height:auto;}
      .filter-bar{grid-template-columns:1fr;padding:18px;}
      .drilldown-header,.compare-row,.asin-row{align-items:stretch;}
      .compare-grid{grid-template-columns:1fr;}
      .chart-box,.insight-box,.compare-card,.risk-section{padding:20px;}
      td,thead th{padding:14px 12px;}
      .project-github,.btn,.asin-input{width:100%;max-width:none;}
      .compare-input-group{min-width:100%;}
    }
  </style>
</head>
<body>

<div class="project-banner">
  <div class="project-banner-inner">
    <div class="project-banner-top">
      <div>
        <div class="project-title">ðŸ›’ Amazon Electronics Quality Dashboard</div>
        <div class="project-subtitle">BT5153 Group 4 &nbsp;Â·&nbsp; NUS Business Analytics AY25/26 S2 &nbsp;Â·&nbsp; Complaint Detection via NMF Topic Modelling</div>
      </div>
      <a class="project-github" href="https://github.com/swathika1/BT5153-team04" target="_blank" rel="noopener">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.17 6.839 9.49.5.09.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.463-1.11-1.463-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.647.35-1.087.636-1.337-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.268 2.75 1.026A9.578 9.578 0 0112 6.836a9.59 9.59 0 012.504.337c1.909-1.294 2.747-1.026 2.747-1.026.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.167 22 16.418 22 12c0-5.523-4.477-10-10-10z"/></svg>
        GitHub Repo
      </a>
    </div>
    <div class="project-team">
      <div class="team-chip">Awale Anagha Dilip <span class="team-id">A0319018H</span></div>
      <div class="team-chip">Elisetti Meghana <span class="team-id">A0319162H</span></div>
      <div class="team-chip">Kumaravel Swathika <span class="team-id">A0318010Y</span></div>
      <div class="team-chip">Tanya Tooley <span class="team-id">A0318087X</span></div>
      <div class="team-chip">Wang Ying <span class="team-id">A0318271H</span></div>
    </div>
  </div>
</div>

<header class="header">
  <div class="header-brand">
    <div class="header-logo">Q</div>
    <div>
      <div class="header-title">Product Quality Dashboard</div>
      <div class="header-sub">BT5153 Group 4 &nbsp;Â·&nbsp; Amazon Electronics Analysis</div>
    </div>
  </div>
  <span class="header-badge">NUS AY25/26 S2</span>
</header>

<div class="wrap">

  <div class="kpi-grid">
    <div class="kpi">
      <div class="kpi-glow" style="background:#356d8c"></div>
      <div class="kpi-label">Total Products</div>
      <div class="kpi-val" style="color:#356d8c">{{ kpis.total_products }}</div>
      <div class="kpi-sub">unique ASINs analysed</div>
    </div>
    <div class="kpi">
      <div class="kpi-glow" style="background:#c65a5a"></div>
      <div class="kpi-label">Bad Products</div>
      <div class="kpi-val" style="color:#c65a5a">{{ kpis.bad_products }}</div>
      <div class="kpi-sub">avg rating â‰¤ 2.0â˜…</div>
    </div>
    <div class="kpi">
      <div class="kpi-glow" style="background:#4c8b6b"></div>
      <div class="kpi-label">Good Products</div>
      <div class="kpi-val" style="color:#4c8b6b">{{ kpis.good_products }}</div>
      <div class="kpi-sub">avg rating â‰¥ 4.0â˜…</div>
    </div>
    <div class="kpi">
      <div class="kpi-glow" style="background:#b7863d"></div>
      <div class="kpi-label">Bad Product Rate</div>
      <div class="kpi-val" style="color:#b7863d">{{ kpis.bad_product_rate }}</div>
      <div class="kpi-sub">of total catalogue</div>
    </div>
    <div class="kpi">
      <div class="kpi-glow" style="background:#356d8c"></div>
      <div class="kpi-label">Mid-tier Products</div>
      <div class="kpi-val" style="color:#356d8c">{{ kpis.mid_products }}</div>
      <div class="kpi-sub">avg rating 2â€“4â˜…</div>
    </div>
  </div>

  <div class="card">
    <div class="section-title">ðŸŒ Global Insights</div>
    <div class="insight-grid" id="global-insights-content">
      <div style="display:flex;align-items:center;gap:12px;padding:16px;color:var(--muted);font-size:14px;">
        <div class="spinner"></div><span>Loading insightsâ€¦</span>
      </div>
    </div>
  </div>

  <div class="two-col">
    <div class="two-col-main card">
      <div class="section-title">ðŸ“Š Top 15 Brands by Bad Product Rate</div>
      <div class="brand-chart-wrap"><canvas id="brandChart"></canvas></div>
    </div>
    <div class="two-col-side card">
      <div class="section-title">ðŸ· Quality Distribution</div>
      <canvas id="qualityChart"></canvas>
    </div>
  </div>

  <div class="card">
    <div class="section-title">ðŸ“‹ Product Catalogue</div>
    <form method="get" class="filter-bar">
      <div class="filter-group">
        <span class="filter-label">Quality Band</span>
        <select name="quality">
          {% for q in qualities %}
            <option value="{{ q }}" {% if q == selected.quality %}selected{% endif %}>{{ q }}</option>
          {% endfor %}
        </select>
      </div>
      <div class="filter-group">
        <span class="filter-label">Brand</span>
        <input name="brand" value="{{ selected.brand }}" placeholder="containsâ€¦" style="width:130px"/>
      </div>
      <div class="filter-group">
        <span class="filter-label">Title</span>
        <input name="title" value="{{ selected.title }}" placeholder="containsâ€¦" style="width:160px"/>
      </div>
      <div class="filter-group">
        <span class="filter-label">Sort By</span>
        <select name="sort">
          {% for s in sorts %}
            <option value="{{ s }}" {% if s == selected.sort %}selected{% endif %}>{{ s }}</option>
          {% endfor %}
        </select>
      </div>
      <div class="filter-group">
        <span class="filter-label">Top N</span>
        <input type="number" min="5" max="200" name="topn" value="{{ selected.topn }}" style="width:72px"/>
      </div>
      <button type="submit" class="btn">Apply Filters</button>
    </form>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>ASIN</th><th>Title</th><th>Brand</th>
            <th style="text-align:right">Reviews</th>
            <th style="text-align:right">Avg Rating</th>
            <th>Quality Band</th>
          </tr>
        </thead>
        <tbody>
          {% for r in rows %}
          <tr>
            <td>
              <button class="asin-link" onclick="inspectAsin('{{ r.asin }}')">{{ r.asin }}</button>
            </td>
            <td style="max-width:300px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;" title="{{ r.title }}">{{ r.title }}</td>
            <td>{{ r.brand }}</td>
            <td style="text-align:right;font-variant-numeric:tabular-nums;">{{ r.reviews }}</td>
            <td style="text-align:right;font-variant-numeric:tabular-nums;">
              <span style="font-weight:700;color:{% if r.avg_rating <= 2 %}#c65a5a{% elif r.avg_rating >= 4 %}#4c8b6b{% else %}#b7863d{% endif %};">
                {{ r.avg_rating }}â˜…
              </span>
            </td>
            <td>
              {% if r.quality_band == 'bad_product' %}<span class="badge badge-bad">â— Bad</span>
              {% elif r.quality_band == 'good_product' %}<span class="badge badge-good">â— Good</span>
              {% else %}<span class="badge badge-mid">â— Mid</span>{% endif %}
            </td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>

  <div class="card">
    <div class="section-title">âš–ï¸ Product Comparison</div>
    <div class="compare-row">
      <div class="compare-input-group">
        <span class="compare-input-label">Product A â€” ASIN</span>
        <input class="asin-input" id="cmp-asin1" placeholder="e.g. B000XXXXXX" style="max-width:260px;"/>
      </div>
      <div class="compare-vs" style="padding-bottom:2px;font-size:15px;">VS</div>
      <div class="compare-input-group">
        <span class="compare-input-label">Product B â€” ASIN</span>
        <input class="asin-input" id="cmp-asin2" placeholder="e.g. B001XXXXXX" style="max-width:260px;"/>
      </div>
      <button class="btn" id="cmp-btn" onclick="runCompare()">Compare</button>
      <div class="spinner" id="cmp-spinner" style="display:none;"></div>
    </div>
    <div id="cmp-result">
      <div class="compare-empty">Enter two ASINs above and press <strong>Compare</strong> to see a side-by-side breakdown.</div>
    </div>
  </div>

  <div class="card">
    <div class="xai-header">
      <span class="xai-header-title">ðŸ§  How the Model Works (Explainable AI)</span>
    </div>
    <div class="xai-steps">
      <div class="xai-step">
        <div class="xai-step-num">1</div>
        <div class="xai-step-text"><strong>Only bad reviews are used.</strong> Reviews rated 2â˜… or below are isolated. This focuses the model exclusively on complaint signal, avoiding dilution from positive feedback.</div>
      </div>
      <div class="xai-step">
        <div class="xai-step-num">2</div>
        <div class="xai-step-text"><strong>TF-IDF converts text into numbers.</strong> Each review becomes a numerical vector. Words that appear frequently in a product's complaints but rarely across all reviews score highest â€” surfacing product-specific issues.</div>
      </div>
      <div class="xai-step">
        <div class="xai-step-num">3</div>
        <div class="xai-step-text"><strong>NMF extracts complaint topics.</strong> Non-negative Matrix Factorization groups co-occurring words into coherent themes (e.g. battery + charging + drain â†’ Battery Issues) without requiring any labelled training data.</div>
      </div>
      <div class="xai-step">
        <div class="xai-step-num">4</div>
        <div class="xai-step-text"><strong>A composite risk score is computed.</strong> Blends bad review rate (50%), distance from 5â˜… (30%), and a neutral verified-purchase prior (20%). Below 0.3 = <span style="color:var(--good);font-weight:700;">LOW RISK</span>, 0.3â€“0.6 = <span style="color:var(--mid);font-weight:700;">MEDIUM RISK</span>, above 0.6 = <span style="color:var(--bad);font-weight:700;">HIGH RISK</span>.</div>
      </div>
    </div>
  </div>

  <div class="card" id="drilldown-card">
    <div class="section-title">ðŸ” Product Drilldown</div>

    <div class="asin-row" style="margin-bottom:28px;">
      <input class="asin-input" id="asin-input" placeholder="Enter ASIN e.g. B000â€¦" value="{{ selected.asin }}"/>
      <button class="btn" id="inspect-btn" onclick="inspectFromInput()">Inspect</button>
      <div class="spinner" id="drilldown-spinner" style="display:none;"></div>
    </div>

    <div class="drilldown-empty" id="drilldown-empty">
      <div class="drilldown-empty-icon">ðŸ”­</div>
      <div style="font-size:15px;">Click any ASIN from the table, or enter one above and press <strong>Inspect</strong></div>
      <div style="font-size:13px;margin-top:8px;color:var(--muted);">Risk scores, complaint themes, and improvement suggestions will appear here</div>
    </div>

    <div id="drilldown-panel">
      <div class="drilldown-header">
        <div style="flex:1;min-width:0;">
          <div class="drilldown-title" id="dd-title">â€”</div>
          <div class="drilldown-meta">
            <span class="meta-chip" id="dd-asin">â€”</span>
            <span class="meta-chip" id="dd-brand">â€”</span>
            <span class="meta-chip" id="dd-reviews">â€”</span>
            <span id="dd-quality-badge"></span>
          </div>
        </div>
        <button class="btn btn-ghost" onclick="closeDrilldown()" style="white-space:nowrap;flex-shrink:0;">âœ• Close</button>
      </div>

      <div class="risk-section">
        <div class="risk-header">
          <div>
            <div style="font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:.08em;margin-bottom:5px;">Composite Risk Score</div>
            <div class="risk-score-big" id="dd-risk-score">â€”</div>
          </div>
          <span class="risk-level-badge" id="dd-risk-level">â€”</span>
          <span class="risk-label-badge" id="dd-risk-label">â€”</span>
        </div>
        <div class="risk-bar-track">
          <div class="risk-bar-fill" id="dd-risk-bar" style="width:0%"></div>
        </div>
        <div class="risk-breakdown">
          <div class="risk-stat">
            <div class="risk-stat-label">Bad Review Rate</div>
            <div class="risk-stat-val" id="dd-bad-rate">â€”</div>
          </div>
          <div class="risk-stat">
            <div class="risk-stat-label">Band Average</div>
            <div class="risk-stat-val" id="dd-band-avg">â€”</div>
          </div>
          <div class="risk-stat">
            <div class="risk-stat-label">vs Band Avg</div>
            <div class="risk-stat-val" id="dd-vs-avg">â€”</div>
          </div>
          <div class="risk-stat">
            <div class="risk-stat-label">Avg Rating</div>
            <div class="risk-stat-val" id="dd-avg-rating">â€”</div>
          </div>
        </div>

        <div style="margin-top:16px;padding-top:14px;border-top:1px solid var(--border);">
          <div style="font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:.08em;margin-bottom:8px;">Decision Recommendation</div>
          <div id="dd-recommendation" style="font-size:14px;font-weight:700;"></div>
        </div>

        <div class="rec-section" id="dd-recs-section" style="display:none;">
          <div class="rec-title">ðŸ’¡ Improvement Suggestions (from NMF complaint themes)</div>
          <div class="rec-chips" id="dd-recs"></div>
        </div>
      </div>

      <div class="chart-row">
        <div class="chart-box" style="flex:1.6;min-width:280px;">
          <div class="chart-title">Complaint Themes (NMF Topic Model)</div>
          <div class="topic-grid" id="dd-topics"></div>
        </div>
        <div class="chart-box" style="min-width:250px;max-width:340px;">
          <div class="chart-title">Rating Distribution</div>
          <canvas id="ratingChart" height="200"></canvas>
        </div>
      </div>
    </div>
  </div>

</div>

<div id="toast">
  <span id="toast-icon">â„¹</span>
  <span id="toast-msg">â€”</span>
</div>

<script>
Chart.register(ChartDataLabels);
const GC='#dbe3ec', TK='#66768a', TT='#1f2937';

new Chart(document.getElementById('qualityChart'),{
  type:'doughnut',
  data:{
    labels:['Bad','Mid','Good'],
    datasets:[{
      data:[{{ kpis.bad_products }},{{ kpis.mid_products }},{{ kpis.good_products }}],
      backgroundColor:['#c65a5a','#b7863d','#4c8b6b'],
      borderColor:'#ffffff',borderWidth:3,hoverOffset:6
    }]
  },
  options:{
    responsive:true,cutout:'62%',
    plugins:{
      legend:{position:'bottom',labels:{color:TK,font:{size:13},padding:16}},
      datalabels:{
        color:'#fff',font:{size:12,weight:'700'},
        formatter:(v,ctx)=>{
          const total=ctx.chart.data.datasets[0].data.reduce((a,b)=>a+b,0);
          return (v/total*100).toFixed(1)+'%';
        }
      }
    }
  }
});

const allBrands={{ brand_stats | tojson }};
const brands=allBrands.filter(b=>b.bad_pct>0);
const bMax=brands.length?Math.ceil(Math.max(...brands.map(b=>b.bad_pct))*1.2/5)*5:100;
new Chart(document.getElementById('brandChart'),{
  type:'bar',
  data:{
    labels:brands.map(b=>b.brand),
    datasets:[{
      data:brands.map(b=>b.bad_pct),
      backgroundColor:brands.map((_,i)=>i<3?'#c65a5a':'rgba(198,90,90,0.38)'),
      borderRadius:5,barThickness:20
    }]
  },
  options:{
    indexAxis:'y',responsive:true,maintainAspectRatio:false,
    plugins:{
      legend:{display:false},
      datalabels:{anchor:'end',align:'end',formatter:v=>v+'%',color:TK,font:{size:11,weight:'600'}}
    },
    scales:{
      x:{beginAtZero:true,max:bMax,ticks:{color:TK,font:{size:12}},grid:{color:GC}},
      y:{ticks:{color:TT,font:{size:12}},grid:{color:GC}}
    },
    layout:{padding:{right:48}}
  }
});

let ratingChart=null;
function buildRatingChart(dist){
  if(ratingChart)ratingChart.destroy();
  ratingChart=new Chart(document.getElementById('ratingChart'),{
    type:'bar',
    data:{
      labels:['1â˜…','2â˜…','3â˜…','4â˜…','5â˜…'],
      datasets:[{
        data:['1','2','3','4','5'].map(k=>dist[k]??0),
        backgroundColor:['#c65a5a','#de8e8e','#d7b26c','#84b79b','#4c8b6b'],
        borderRadius:5
      }]
    },
    options:{
      responsive:true,
      plugins:{legend:{display:false},datalabels:{display:false}},
      scales:{
        y:{beginAtZero:true,ticks:{color:TK,font:{size:12}},grid:{color:GC}},
        x:{ticks:{color:TT,font:{size:12}},grid:{color:GC}}
      }
    }
  });
}

let toastT;
function showToast(msg,icon='â„¹'){
  const el=document.getElementById('toast');
  document.getElementById('toast-msg').textContent=msg;
  document.getElementById('toast-icon').textContent=icon;
  el.classList.add('show');
  clearTimeout(toastT);
  toastT=setTimeout(()=>el.classList.remove('show'),3500);
}

function closeDrilldown(){
  document.getElementById('drilldown-panel').classList.remove('visible');
  document.getElementById('drilldown-empty').style.display='';
  document.getElementById('asin-input').value='';
}

function inspectFromInput(){
  const v=document.getElementById('asin-input').value.trim();
  if(!v){showToast('Please enter an ASIN first','âš ï¸');return;}
  inspectAsin(v);
}

document.getElementById('asin-input').addEventListener('keydown',e=>{
  if(e.key==='Enter')inspectFromInput();
});

async function inspectAsin(asin){
  document.getElementById('asin-input').value=asin;
  document.getElementById('drilldown-empty').style.display='none';
  document.getElementById('drilldown-panel').classList.remove('visible');
  document.getElementById('drilldown-spinner').style.display='flex';
  document.getElementById('inspect-btn').disabled=true;
  try{
    const res=await fetch('/api/product/'+encodeURIComponent(asin));
    if(!res.ok){showToast('ASIN not found: '+asin,'âŒ');throw new Error('not found');}
    const d=await res.json();
    populateDrilldown(d);
    document.getElementById('drilldown-card').scrollIntoView({behavior:'smooth',block:'start'});
  }catch(e){
    document.getElementById('drilldown-empty').style.display='';
  }finally{
    document.getElementById('drilldown-spinner').style.display='none';
    document.getElementById('inspect-btn').disabled=false;
  }
}

function populateDrilldown(d){
  document.getElementById('dd-title').textContent=d.title||d.asin;
  document.getElementById('dd-asin').textContent=d.asin;
  document.getElementById('dd-brand').textContent='ðŸ· '+(d.brand||'Unknown');
  document.getElementById('dd-reviews').textContent='ðŸ“ '+(d.reviews||0).toLocaleString()+' reviews';
  const qb=d.quality_band||'';
  const qEl=document.getElementById('dd-quality-badge');
  if(qb==='bad_product')qEl.innerHTML='<span class="badge badge-bad">â— Bad Product</span>';
  else if(qb==='good_product')qEl.innerHTML='<span class="badge badge-good">â— Good Product</span>';
  else qEl.innerHTML='<span class="badge badge-mid">â— Mid Product</span>';

  const score=d.risk_score||0;
  const rsEl=document.getElementById('dd-risk-score');
  rsEl.textContent=score.toFixed(3);
  rsEl.style.color=d.risk_color||'#fff';

  const rlvEl=document.getElementById('dd-risk-level');
  rlvEl.textContent=d.risk_level||'â€”';
  rlvEl.style.background=(d.risk_color||'#888')+'22';
  rlvEl.style.color=d.risk_color||'#888';
  rlvEl.style.border='1px solid '+(d.risk_color||'#888')+'55';

  const rl=d.risk_label||'Unknown';
  const rlEl=document.getElementById('dd-risk-label');
  rlEl.textContent=rl;
  rlEl.className='risk-label-badge badge '+(rl==='High Risk'?'badge-bad':rl==='Low Risk'?'badge-good':'badge-mid');

  document.getElementById('dd-risk-bar').style.width=Math.min(score*100,100)+'%';
  document.getElementById('dd-risk-bar').style.background=d.risk_color||'#888';

  const brEl=document.getElementById('dd-bad-rate');
  brEl.textContent=d.bad_rate_pct!=null?d.bad_rate_pct+'%':'N/A';
  brEl.style.color=d.risk_color||TT;
  document.getElementById('dd-band-avg').textContent=(d.band_avg_pct??'â€”')+'%';

  const vsEl=document.getElementById('dd-vs-avg');
  vsEl.innerHTML=d.vs_avg==='better'
    ?'<span class="vs-chip vs-better">â–¼ Better than avg</span>'
    :'<span class="vs-chip vs-worse">â–² Worse than avg</span>';

  const arEl=document.getElementById('dd-avg-rating');
  arEl.textContent=(d.avg_rating||0).toFixed(2)+'â˜…';
  arEl.style.color=d.avg_rating>=4?'#4c8b6b':d.avg_rating<=2?'#c65a5a':'#b7863d';

  const recEl=document.getElementById('dd-recommendation');
  recEl.textContent=d.recommendation||'â€”';
  recEl.style.color=qb==='bad_product'?'#c65a5a':qb==='good_product'?'#4c8b6b':'#b7863d';

  const recs=d.topic_recommendations||[];
  const recsSec=document.getElementById('dd-recs-section');
  const recsEl=document.getElementById('dd-recs');
  if(recs.length>0){
    recsEl.innerHTML=recs.map(r=>`<span class="rec-chip">${r}</span>`).join('');
    recsSec.style.display='';
  }else{
    recsSec.style.display='none';
  }

  const topicsEl=document.getElementById('dd-topics');
  if(d.topics&&d.topics.length>0){
    topicsEl.innerHTML=d.topics.map((words,i)=>{
      const lbl=d.topic_labels&&d.topic_labels[i]?d.topic_labels[i]:'';
      return `<div class="topic-card">
        <div class="topic-num">Topic ${i+1}</div>
        <div class="topic-words">${words.map(w=>`<span class="topic-word">${w}</span>`).join('')}</div>
        ${lbl?`<div class="topic-interp">${lbl}</div>`:''}
      </div>`;
    }).join('');
  }else if(d.top_terms&&d.top_terms.length>0){
    topicsEl.innerHTML=`<div class="topic-card">
      <div class="topic-num">Top Complaint Terms (insufficient data for NMF)</div>
      <div class="topic-words">${d.top_terms.map(w=>`<span class="topic-word">${w}</span>`).join('')}</div>
    </div>`;
  }else{
    topicsEl.innerHTML='<p style="color:var(--muted);font-size:14px;padding:10px 0;">No bad review data found for this product.</p>';
  }

  buildRatingChart(d.rating_dist||{});
  document.getElementById('drilldown-panel').classList.add('visible');
  showToast('Loaded: '+d.asin,'âœ…');
}

(function(){
  const initial='{{ selected.asin | e }}';
  if(initial)inspectAsin(initial);
})();

async function runCompare(){
  const a1=(document.getElementById('cmp-asin1').value||'').trim();
  const a2=(document.getElementById('cmp-asin2').value||'').trim();
  if(!a1||!a2){showToast('Please enter both ASINs','âš ï¸');return;}
  if(a1===a2){showToast('Enter two different ASINs','âš ï¸');return;}
  const resultEl=document.getElementById('cmp-result');
  const spinner=document.getElementById('cmp-spinner');
  const btn=document.getElementById('cmp-btn');
  resultEl.innerHTML='';
  spinner.style.display='flex';
  btn.disabled=true;
  try{
    const res=await fetch('/api/compare?asin1='+encodeURIComponent(a1)+'&asin2='+encodeURIComponent(a2));
    const json=await res.json();
    if(!res.ok){
      const msg=json.error||'One or both ASINs not found';
      resultEl.innerHTML='<div class="compare-empty" style="color:var(--bad);">'+msg+'</div>';
      showToast(msg,'âŒ');
      return;
    }
    resultEl.innerHTML=renderCompare(json.product1,json.product2);
  }catch(err){
    resultEl.innerHTML='<div class="compare-empty" style="color:var(--bad);">Error: '+err.message+'</div>';
    showToast(err.message,'âŒ');
  }finally{
    spinner.style.display='none';
    btn.disabled=false;
  }
}
function renderCompare(a,b){
  const ratingWin=a.avg_rating>=b.avg_rating?'A':'B';
  const badA=a.bad_rate_pct!=null?a.bad_rate_pct:999;
  const badB=b.bad_rate_pct!=null?b.bad_rate_pct:999;
  const badWin=badA<=badB?'A':'B';
  const riskRank={'LOW RISK':0,'MEDIUM RISK':1,'HIGH RISK':2};
  const riskA=riskRank[a.risk_level]??1;
  const riskB=riskRank[b.risk_level]??1;
  const riskWin=riskA<=riskB?'A':'B';
  const aWins=(ratingWin==='A'?1:0)+(badWin==='A'?1:0)+(riskWin==='A'?1:0);
  const bWins=3-aWins;
  const overallWin=aWins>bWins?'A':bWins>aWins?'B':'tie';

  function ratingColor(v){return v>=4?'#4c8b6b':v<=2?'#c65a5a':'#b7863d';}
  function badColor(v){if(v==null||v===999)return 'var(--muted)';return v<=15?'#4c8b6b':v<=35?'#b7863d':'#c65a5a';}
  function riskColor(lvl){return lvl==='LOW RISK'?'#4c8b6b':lvl==='HIGH RISK'?'#c65a5a':'#b7863d';}

  function card(d,side){
    const isOverallWin=overallWin===side;
    const isRatingWin=ratingWin===side;
    const isBadWin=badWin===side;
    const isRiskWin=riskWin===side;
    const badPct=d.bad_rate_pct!=null?d.bad_rate_pct+'%':'N/A';
    const safeTitle=(d.title||d.asin).replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    return `<div class="compare-card${isOverallWin?' winner':''}">
      <div>
        <div class="compare-card-name" title="${safeTitle}">${safeTitle}</div>
        <div class="compare-card-asin">${d.asin} &nbsp;Â·&nbsp; ðŸ· ${d.brand||'Unknown'} &nbsp;Â·&nbsp; ðŸ“ ${(d.reviews||0).toLocaleString()} reviews</div>
      </div>
      <div class="compare-metrics">
        <div class="compare-metric">
          <div class="compare-metric-label">Avg Rating</div>
          <div class="compare-metric-val" style="color:${ratingColor(d.avg_rating)}">${(d.avg_rating||0).toFixed(2)}â˜…</div>
          ${isRatingWin?'<div class="compare-win-tag">â–² Better</div>':''}
        </div>
        <div class="compare-metric">
          <div class="compare-metric-label">Bad Review Rate</div>
          <div class="compare-metric-val" style="color:${badColor(d.bad_rate_pct)}">${badPct}</div>
          ${isBadWin?'<div class="compare-win-tag">â–² Better</div>':''}
        </div>
        <div class="compare-metric">
          <div class="compare-metric-label">Risk Level</div>
          <div class="compare-metric-val" style="font-size:1.1rem;color:${riskColor(d.risk_level||'')}">${d.risk_level||'Unknown'}</div>
          ${isRiskWin?'<div class="compare-win-tag">â–² Better</div>':''}
        </div>
      </div>
      <div class="compare-rec" style="color:${d.quality_band==='bad_product'?'#c65a5a':d.quality_band==='good_product'?'#4c8b6b':'#b7863d'}">${d.recommendation||''}</div>
      ${isOverallWin?'<div class="compare-best-label">âœ“ Recommended pick based on overall metrics</div>':''}
    </div>`;
  }

  return `<div class="compare-grid">${card(a,'A')}${card(b,'B')}</div>`;
}

document.getElementById('cmp-asin1').addEventListener('keydown',e=>{if(e.key==='Enter')runCompare();});
document.getElementById('cmp-asin2').addEventListener('keydown',e=>{if(e.key==='Enter')runCompare();});

async function loadGlobalInsights(){
  try{
    const res=await fetch('/api/global-insights');
    const d=await res.json();
    const el=document.getElementById('global-insights-content');
    const maxPct=Math.max(...(d.top3_worst_brands||[]).map(b=>b.bad_pct||0),1);
    const bandRows=Object.entries(d.band_counts||{}).map(([k,v])=>{
      const col=k.includes('Bad')?'var(--bad)':k.includes('Good')?'var(--good)':'var(--mid)';
      return `<div style="display:flex;align-items:center;gap:10px;margin-bottom:9px;">
        <span style="width:9px;height:9px;border-radius:50%;background:${col};flex-shrink:0;"></span>
        <span style="font-size:13px;color:var(--muted);flex:1;">${k}</span>
        <span style="font-weight:700;font-size:14px;">${v.toLocaleString()}</span>
      </div>`;
    }).join('');
    const brandRows=(d.top3_worst_brands||[]).map((b,i)=>`
      <div class="worst-brand-row">
        <span class="rank-num">${i+1}</span>
        <span style="flex:1;font-size:14px;font-weight:600;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">${b.brand}</span>
        <div class="brand-bar-outer"><div class="brand-bar-inner" style="width:${(b.bad_pct/maxPct*100).toFixed(1)}%"></div></div>
        <span class="badge badge-bad" style="margin-left:10px;flex-shrink:0;">${b.bad_pct}%</span>
      </div>`).join('');
    el.innerHTML=`
      <div class="insight-box">
        <div class="insight-label">ðŸ“¦ Quality Band Breakdown</div>
        <div style="font-size:1rem;font-weight:800;margin-bottom:10px;">${d.dominant_band}</div>
        <div style="font-size:12px;color:var(--muted);margin-bottom:14px;">${(d.dominant_band_count||0).toLocaleString()} products in largest band</div>
        ${bandRows}
      </div>
      <div class="insight-box" style="flex:1.5;">
        <div class="insight-label">ðŸš¨ Top 3 Worst Brands (Bad Product Rate)</div>
        ${brandRows||'<p class="muted" style="font-size:13px;">No data available</p>'}
      </div>`;
  }catch(e){
    document.getElementById('global-insights-content').innerHTML=
      '<p style="color:var(--muted);font-size:14px;padding:10px;">Could not load global insights.</p>';
  }
}
loadGlobalInsights();
</script>
</body>
</html>
"""


@app.route("/")
def home() -> str:
    meta = load_meta()

    quality = request.args.get("quality", "ALL")
    brand = request.args.get("brand", "").strip()
    title = request.args.get("title", "").strip()
    sort = request.args.get("sort", "avg_rating_asc")
    asin = request.args.get("asin", "").strip()
    topn = max(5, min(200, int(request.args.get("topn", "30"))))

    df = meta.copy()
    if quality != "ALL":
        df = df[df["quality_band"] == quality]
    if brand:
        df = df[df["brand"].str.contains(brand, case=False, na=False)]
    if title:
        df = df[df["title"].str.contains(title, case=False, na=False)]

    if sort == "avg_rating_asc":
        df = df.sort_values(["avg_rating", "reviews"], ascending=[True, False])
    elif sort == "avg_rating_desc":
        df = df.sort_values(["avg_rating", "reviews"], ascending=[False, False])
    elif sort == "bad_review_rate_desc":
        df = df.sort_values(["avg_rating", "reviews"], ascending=[True, False])
    else:
        df = df.sort_values(["reviews", "avg_rating"], ascending=[False, False])

    rows = [_safe_dict(r) for r in df.head(topn).to_dict(orient="records")]

    kpis = {
        "total_products": int(meta["asin"].nunique()),
        "bad_products": int((meta["quality_band"] == "bad_product").sum()),
        "mid_products": int((meta["quality_band"] == "mid_product").sum()),
        "good_products": int((meta["quality_band"] == "good_product").sum()),
        "bad_product_rate": f"{float((meta['quality_band'] == 'bad_product').mean()):.1%}",
    }

    brand_stats = get_brand_stats(meta)

    return render_template_string(
        TEMPLATE,
        kpis=kpis,
        rows=rows,
        brand_stats=brand_stats,
        qualities=["ALL", "bad_product", "mid_product", "good_product"],
        sorts=["avg_rating_asc", "avg_rating_desc", "bad_review_rate_desc", "reviews_desc"],
        selected={"quality": quality, "brand": brand, "title": title, "sort": sort, "asin": asin, "topn": topn},
    )


@app.route("/api/product/<asin>")
def api_product(asin: str):
    meta = load_meta()
    payload = _build_product_payload(asin, meta)
    if payload is None:
        return jsonify({"error": "ASIN not found"}), 404
    return jsonify(payload)


@app.route("/api/global-insights")
def api_global_insights():
    meta = load_meta()
    band_counts = {k: int(v) for k, v in meta["quality_band"].value_counts().to_dict().items()}
    brand_stats = get_brand_stats(meta)
    band_label_map = {
        "bad_product": "Bad Products (avg â‰¤ 2.0â˜…)",
        "mid_product": "Mid-tier Products (avg 2â€“4â˜…)",
        "good_product": "Good Products (avg â‰¥ 4.0â˜…)",
    }
    dominant_band = max(band_counts, key=band_counts.get, default="mid_product")
    return jsonify({
        "band_counts": {band_label_map.get(k, k): v for k, v in band_counts.items()},
        "dominant_band": band_label_map.get(dominant_band, dominant_band),
        "dominant_band_count": int(band_counts.get(dominant_band, 0)),
        "top3_worst_brands": [
            {"brand": str(b["brand"]), "bad_pct": float(b["bad_pct"]), "products": int(b["products"])}
            for b in brand_stats[:3]
        ],
    })


@app.route("/api/compare")
def api_compare():
    asin1 = request.args.get("asin1", "").strip()
    asin2 = request.args.get("asin2", "").strip()
    if not asin1 or not asin2:
        return jsonify({"error": "asin1 and asin2 are required"}), 400

    meta = load_meta()
    band_avgs = get_band_avg_bad_rates()

    def _lite(asin):
        one = meta[meta["asin"] == asin]
        if one.empty:
            return None
        row = _safe_dict(one.iloc[0].to_dict())
        qb = str(row.get("quality_band", ""))
        avg_rating = float(row.get("avg_rating", 0.0))
        product_bad_rate = get_product_bad_rate(asin)
        band_avg = float(band_avgs.get(qb, 0.0))
        bad_rate_pct = round(product_bad_rate * 100, 1) if product_bad_rate is not None else None
        br = product_bad_rate if product_bad_rate is not None else 0.0
        if product_bad_rate is None:
            risk_label = "Unknown"
        elif product_bad_rate > band_avg + 0.05:
            risk_label = "High Risk"
        elif product_bad_rate >= band_avg - 0.05:
            risk_label = "Medium Risk"
        else:
            risk_label = "Low Risk"
        risk_score = round((br * 0.5) + ((5.0 - avg_rating) / 5.0 * 0.3) + (0.5 * 0.2), 3)
        if risk_score < 0.3:
            risk_level, risk_color = "LOW RISK", "#22c55e"
        elif risk_score < 0.6:
            risk_level, risk_color = "MEDIUM RISK", "#f59e0b"
        else:
            risk_level, risk_color = "HIGH RISK", "#ef4444"
        rec_map = {
            "bad_product": "âš  Avoid â€” high complaint volume.",
            "mid_product": "âš¡ Mixed experience â€” review before purchasing.",
            "good_product": "âœ“ Generally reliable.",
        }
        return {
            "asin": str(row.get("asin", asin)),
            "title": str(row.get("title", asin)),
            "brand": str(row.get("brand", "Unknown")),
            "avg_rating": avg_rating,
            "reviews": int(row.get("reviews", 0)),
            "quality_band": qb,
            "bad_rate_pct": bad_rate_pct,
            "band_avg_pct": round(band_avg * 100, 1),
            "risk_label": risk_label,
            "risk_score": risk_score,
            "risk_level": risk_level,
            "risk_color": risk_color,
            "recommendation": rec_map.get(qb, ""),
        }

    d1 = _lite(asin1)
    d2 = _lite(asin2)
    missing = []
    if d1 is None: missing.append(f"{asin1} not found")
    if d2 is None: missing.append(f"{asin2} not found")
    if missing:
        return jsonify({"error": ", ".join(missing)}), 404
    return jsonify({"product1": d1, "product2": d2})


if __name__ == "__main__":
    debug_mode = os.getenv("FLASK_DEBUG", "0") == "1"
    app.run(host="0.0.0.0", port=5000, debug=debug_mode, use_reloader=False, threaded=True)